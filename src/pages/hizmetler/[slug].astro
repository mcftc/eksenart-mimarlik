---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/consts";

export async function getStaticPaths() {
  const services = await getCollection("services", (s) => !s.data.draft);
  return services.map((service) => ({ params: { slug: service.id }, props: { service } }));
}

const { service } = Astro.props;
const { Content } = await render(service);
const d = service.data;
const path = `/hizmetler/${service.id}/`;

const related = (await getCollection("services", (s) => d.related.includes(s.id))).sort(
  (a, b) => a.data.order - b.data.order
);

const serviceSchema = {
  "@type": "Service",
  name: d.title,
  serviceType: d.title,
  description: d.metaDescription ?? d.excerpt,
  provider: { "@id": `${SITE.url}/#organization` },
  areaServed: { "@type": "City", name: "İstanbul" },
  url: SITE.url + path,
};
const breadcrumb = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Ana Sayfa", item: SITE.url + "/" },
    { "@type": "ListItem", position: 2, name: "Hizmetler", item: SITE.url + "/hizmetler/" },
    { "@type": "ListItem", position: 3, name: d.title, item: SITE.url + path },
  ],
};
---

<BaseLayout
  title={d.metaTitle ?? `${d.title} | İstanbul | Eksenart Mimarlık`}
  description={d.metaDescription ?? d.excerpt}
  path={path}
  jsonLd={[serviceSchema, breadcrumb]}
>
  <article class="section">
    <div class="container-page max-w-4xl">
      <nav aria-label="Sayfa yolu" class="flex items-center gap-2 text-sm text-muted">
        <a href="/" class="hover:text-accent">Ana Sayfa</a><span aria-hidden="true">/</span>
        <a href="/hizmetler/" class="hover:text-accent">Hizmetler</a><span aria-hidden="true">/</span>
        <span class="text-ink">{d.title}</span>
      </nav>

      <h1 class="mt-6 text-[length:var(--text-h1)]">{d.title}</h1>
      <p class="mt-5 font-serif text-[length:var(--text-lead)] text-ink-2">{d.excerpt}</p>

      <div class="prose-eksen mt-10 space-y-5 text-ink-2 [&_a]:text-accent [&_a:hover]:underline [&_p]:leading-relaxed">
        <Content />
      </div>

      {
        d.faqs.length > 0 && (
          <section class="mt-14">
            <h2 class="text-[length:var(--text-h3)]">Sıkça Sorulan Sorular</h2>
            <div class="mt-5 divide-y divide-line border-y border-line">
              {d.faqs.map((f) => (
                <details class="group py-4">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-ink [&::-webkit-details-marker]:hidden">
                    {f.q}
                    <span class="text-accent transition-transform group-open:rotate-45" aria-hidden="true">+</span>
                  </summary>
                  <p class="mt-3 text-sm leading-relaxed text-muted">{f.a}</p>
                </details>
              ))}
            </div>
          </section>
        )
      }

      {
        related.length > 0 && (
          <section class="mt-14">
            <p class="eyebrow">İlgili hizmetler</p>
            <div class="mt-4 flex flex-wrap gap-3">
              {related.map((r) => (
                <a href={`/hizmetler/${r.id}/`} class="border border-line px-4 py-2 text-sm transition-colors hover:border-accent hover:text-accent">
                  {r.data.title}
                </a>
              ))}
            </div>
          </section>
        )
      }

      <div class="mt-16 flex flex-col items-start gap-4 border-t border-line pt-10 sm:flex-row sm:items-center sm:justify-between">
        <p class="font-serif text-xl text-ink">Bu hizmet için görüşelim mi?</p>
        <a href="/iletisim/" class="inline-flex items-center gap-2 bg-accent px-6 py-3 text-sm font-medium text-canvas transition-colors hover:bg-accent-strong">
          Teklif alın <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
