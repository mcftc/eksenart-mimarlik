---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/consts";

const aboutSchema = {
  "@type": "AboutPage",
  name: "Stüdyo — Eksenart Mimarlık",
  url: SITE.url + "/hakkimizda/",
  mainEntity: { "@id": `${SITE.url}/#organization` },
};
const values = [
  { t: "Tek elden süreç", d: "Tasarımdan yapıma aynı ekip; fikir hiçbir aşamada kaybolmaz." },
  { t: "Bağlama saygı", d: "Her proje arsasını, ışığını ve kullanıcısını dinleyerek başlar." },
  { t: "Detay ve kalıcılık", d: "Doğru malzeme, doğru işçilik; zamanla güzelleşen yapılar." },
];
---

<BaseLayout
  title="Stüdyo | Hakkımızda | Eksenart Mimarlık"
  description="Eksenart Mimarlık; İstanbul merkezli, mimari tasarımdan anahtar teslim yapıma tek elden hizmet veren bir mimarlık ve inşaat stüdyosu."
  path="/hakkimizda/"
  jsonLd={aboutSchema}
>
  <section class="section">
    <div class="container-page max-w-4xl">
      <p class="eyebrow">Stüdyo</p>
      <h1 class="mt-4 text-[length:var(--text-h1)]">Mimariyi bütünüyle tasarlayan bir stüdyo.</h1>
      <p class="mt-6 font-serif text-[length:var(--text-h3)] leading-snug text-ink-2">
        Eksenart Mimarlık, İstanbul'da mimari proje, iç mimarlık ve mimari tasarımı
        tek çatı altında buluşturur. Sürecin her aşamasının aynı ekip tarafından
        yürütülmesi, sonucun bütünleşik ve tutarlı olmasını sağlar.
      </p>

      <div class="mt-12 grid gap-px border border-line bg-line sm:grid-cols-3">
        {
          values.map((v) => (
            <div class="bg-canvas p-7">
              <h2 class="font-display text-lg text-ink">{v.t}</h2>
              <p class="mt-2 text-sm text-muted">{v.d}</p>
            </div>
          ))
        }
      </div>

      <div class="mt-12 space-y-5 text-ink-2 [&_p]:leading-relaxed">
        <p>
          Konut ve villalardan ticari mekânlara, kapsamlı tadilatlardan kentsel
          dönüşüme kadar geniş bir yelpazede çalışıyoruz. Her ölçekte aynı titizlikle;
          önce ihtiyacı ve bağlamı anlıyor, sonra çözümü tasarlayıp hayata geçiriyoruz.
        </p>
        <p>
          Eksenart aynı zamanda fuar ve stand tasarımı disiplininde de üretim yapıyor.
          Fuar standı işleri için kardeş markamız
          <a href={SITE.sister.url} class="text-accent hover:underline">{SITE.sister.name.replace("Eksenart ", "")} ↗</a>
          sayfasını ziyaret edebilirsiniz.
        </p>
      </div>

      <div class="mt-14 flex flex-col items-start gap-4 border-t border-line pt-10 sm:flex-row sm:items-center sm:justify-between">
        <p class="font-serif text-xl text-ink">Birlikte çalışalım mı?</p>
        <a href="/iletisim/" class="inline-flex items-center gap-2 bg-accent px-6 py-3 text-sm font-medium text-canvas transition-colors hover:bg-accent-strong">
          İletişime geçin <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
