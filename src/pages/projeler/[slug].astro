---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE, SERVICE_HUBS } from "@/consts";

export async function getStaticPaths() {
  const projects = (await getCollection("projects", (p) => !p.data.draft)).sort(
    (a, b) => b.data.year - a.data.year
  );
  return projects.map((project, i) => ({
    params: { slug: project.id },
    props: { project, next: projects[(i + 1) % projects.length] },
  }));
}

const { project, next } = Astro.props;
const { Content } = await render(project);
const d = project.data;
const path = `/projeler/${project.id}/`;

const statusLabels: Record<string, string> = {
  tamamlandi: "Tamamlandı",
  devam: "Devam ediyor",
  konsept: "Konsept",
};
const serviceTitle = (slug: string) => SERVICE_HUBS.find((s) => s.slug === slug)?.title ?? slug;

const specs = [
  { label: "Konum", value: d.location },
  { label: "Yıl", value: String(d.year) },
  { label: "Alan", value: d.area_m2 ? `${d.area_m2} m²` : null },
  { label: "Süre", value: d.duration ?? null },
  { label: "Durum", value: statusLabels[d.status] },
].filter((s) => s.value);

const creativeWork = {
  "@type": "CreativeWork",
  name: d.title,
  description: d.summary,
  dateCreated: String(d.year),
  locationCreated: { "@type": "Place", name: d.location },
  creator: { "@id": `${SITE.url}/#organization` },
  image: new URL(d.cover, SITE.url).href,
  url: SITE.url + path,
};
const breadcrumb = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Ana Sayfa", item: SITE.url + "/" },
    { "@type": "ListItem", position: 2, name: "Projeler", item: SITE.url + "/projeler/" },
    { "@type": "ListItem", position: 3, name: d.title, item: SITE.url + path },
  ],
};
---

<BaseLayout
  title={`${d.title} | Proje | Eksenart Mimarlık`}
  description={d.summary}
  path={path}
  image={d.cover}
  type="article"
  jsonLd={[creativeWork, breadcrumb]}
>
  <!-- Full-bleed cover -->
  <figure class="border-b border-line">
    <img
      src={d.cover}
      alt={d.coverAlt}
      width="1600"
      height="1000"
      fetchpriority="high"
      class="aspect-[16/10] w-full object-cover"
    />
  </figure>

  <article class="section">
    <div class="container-page">
      <nav aria-label="Sayfa yolu" class="flex items-center gap-2 text-sm text-muted">
        <a href="/" class="hover:text-accent">Ana Sayfa</a><span aria-hidden="true">/</span>
        <a href="/projeler/" class="hover:text-accent">Projeler</a><span aria-hidden="true">/</span>
        <span class="text-ink">{d.title}</span>
      </nav>

      <div class="mt-8 grid gap-10 lg:grid-cols-12">
        <header class="lg:col-span-7">
          <h1 class="text-[length:var(--text-h1)]">{d.title}</h1>
          <p class="mt-5 font-serif text-[length:var(--text-lead)] text-ink-2">{d.summary}</p>
        </header>

        <dl class="grid grid-cols-2 gap-y-5 self-start border-t border-line pt-6 lg:col-span-5 lg:border-l lg:border-t-0 lg:pl-8 lg:pt-0">
          {
            specs.map((s) => (
              <div>
                <dt class="text-xs uppercase tracking-wider text-muted">{s.label}</dt>
                <dd class="nums mt-1 text-ink">{s.value}</dd>
              </div>
            ))
          }
          <div class="col-span-2">
            <dt class="text-xs uppercase tracking-wider text-muted">Hizmet</dt>
            <dd class="mt-2 flex flex-wrap gap-2">
              {
                d.services.map((slug) => (
                  <a href={`/hizmetler/${slug}/`} class="border border-line px-3 py-1 text-xs transition-colors hover:border-accent hover:text-accent">
                    {serviceTitle(slug)}
                  </a>
                ))
              }
            </dd>
          </div>
        </dl>
      </div>

      <div class="mt-12 max-w-3xl space-y-5 text-ink-2 [&_p]:leading-relaxed">
        <Content />
      </div>

      {
        d.gallery.length > 0 && (
          <div class="mt-14 grid gap-6 sm:grid-cols-2">
            {d.gallery.map((g, i) => (
              <figure class:list={[i % 3 === 0 ? "sm:col-span-2" : ""]}>
                <img
                  src={g.src}
                  alt={g.alt}
                  width="1600"
                  height="1000"
                  loading="lazy"
                  class="w-full border border-line object-cover"
                />
                {g.caption && <figcaption class="mt-2 text-sm text-muted">{g.caption}</figcaption>}
              </figure>
            ))}
          </div>
        )
      }

      {
        d.materials.length > 0 && (
          <section class="mt-14 border-t border-line pt-8">
            <p class="eyebrow">Malzemeler</p>
            <ul class="mt-3 flex flex-wrap gap-x-6 gap-y-2 text-sm text-ink-2">
              {d.materials.map((m) => <li>{m}</li>)}
            </ul>
          </section>
        )
      }
    </div>
  </article>

  <!-- Next project -->
  {
    next && next.id !== project.id && (
      <a href={`/projeler/${next.id}/`} class="group block border-t border-line bg-canvas-2">
        <div class="container-page flex items-center justify-between gap-6 py-10">
          <div>
            <p class="eyebrow">Sonraki proje</p>
            <p class="mt-2 font-display text-2xl text-ink transition-colors group-hover:text-accent">{next.data.title}</p>
          </div>
          <span class="text-2xl text-accent" aria-hidden="true">→</span>
        </div>
      </a>
    )
  }
</BaseLayout>
