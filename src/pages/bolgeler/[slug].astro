---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE, SERVICE_HUBS } from "@/consts";

export async function getStaticPaths() {
  const items = await getCollection("bolgeler", (b) => !b.data.draft);
  return items.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const path = `/bolgeler/${entry.id}/`;
const serviceTitle = (slug: string) => SERVICE_HUBS.find((s) => s.slug === slug)?.title ?? slug;

const service = {
  "@type": "Service",
  name: `${d.ilce} Mimarlık ve Mimari Proje`,
  provider: { "@id": `${SITE.url}/#organization` },
  areaServed: { "@type": "City", name: d.ilce },
  url: SITE.url + path,
};
const breadcrumb = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Ana Sayfa", item: SITE.url + "/" },
    { "@type": "ListItem", position: 2, name: "Bölgeler", item: SITE.url + "/bolgeler/" },
    { "@type": "ListItem", position: 3, name: d.ilce, item: SITE.url + path },
  ],
};
---

<BaseLayout
  title={d.metaTitle ?? d.title}
  description={d.metaDescription ?? d.intro}
  path={path}
  jsonLd={[service, breadcrumb]}
>
  <article class="section">
    <div class="container-page max-w-4xl">
      <nav aria-label="Sayfa yolu" class="flex items-center gap-2 text-sm text-muted">
        <a href="/" class="hover:text-accent">Ana Sayfa</a><span aria-hidden="true">/</span>
        <a href="/bolgeler/" class="hover:text-accent">Bölgeler</a><span aria-hidden="true">/</span>
        <span class="text-ink">{d.ilce}</span>
      </nav>

      <h1 class="mt-6 text-[length:var(--text-h1)]">{d.title}</h1>
      <p class="mt-5 font-serif text-[length:var(--text-lead)] text-ink-2">{d.intro}</p>

      <div class="prose-eksen mt-10"><Content /></div>

      {
        d.services.length > 0 && (
          <section class="mt-12">
            <p class="eyebrow">İlgili hizmetler</p>
            <div class="mt-4 flex flex-wrap gap-3">
              {d.services.map((s) => (
                <a href={`/hizmetler/${s}/`} class="border border-line px-4 py-2 text-sm transition-colors hover:border-accent hover:text-accent">
                  {serviceTitle(s)}
                </a>
              ))}
            </div>
          </section>
        )
      }

      <div class="mt-16 flex flex-col items-start gap-4 border-t border-line pt-10 sm:flex-row sm:items-center sm:justify-between">
        <p class="font-serif text-xl text-ink">{d.ilce}'de bir projeniz mi var?</p>
        <a href="/iletisim/" class="inline-flex items-center gap-2 bg-accent px-6 py-3 text-sm font-medium text-canvas transition-colors hover:bg-accent-strong">
          İletişime geçin <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
