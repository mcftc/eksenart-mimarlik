---
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Açık/koyu tema değiştir"
  title="Tema"
  class="grid h-9 w-9 place-items-center rounded-full border border-line text-ink-2 transition-colors hover:border-accent hover:text-accent"
>
  <svg class="t-sun h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
  </svg>
  <svg class="t-moon hidden h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
  </svg>
</button>

<style>
  .t-moon { display: none; }
  :global(.light) .t-sun { display: none; }
  :global(.light) .t-moon { display: block; }
</style>

<script>
  function bindThemeToggle() {
    const btn = document.getElementById("theme-toggle") as HTMLButtonElement | null;
    if (!btn || btn.dataset.bound) return;
    btn.dataset.bound = "1";
    btn.addEventListener("click", () => {
      const isLight = document.documentElement.classList.toggle("light");
      try {
        localStorage.theme = isLight ? "light" : "dark";
      } catch (e) {
        /* ignore */
      }
    });
  }
  bindThemeToggle();
  document.addEventListener("astro:page-load", bindThemeToggle);
</script>
